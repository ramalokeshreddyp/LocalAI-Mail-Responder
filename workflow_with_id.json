      "updatedAt": "2026-04-12T00:00:00.000Z",
      "id": "tag-email",
      "name": "email-automation"
    }
  ],
  "triggerCount": 0,
  "updatedAt": "2026-04-12T00:00:00.000Z",
  "versionId": "1a2b3c4d-e5f6-7890-abcd-ef1234567890",
  "id": "local-ai-email-responder"
}