# ============================================================
# Local AI Email Auto-Responder — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to version control.
# ============================================================

# --- n8n Configuration ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- IMAP Configuration (Incoming Email) ---
# Host of your IMAP server (e.g., imap.gmail.com)
IMAP_HOST=imap.example.com
# IMAP port — 993 for SSL, 143 for STARTTLS
IMAP_PORT=993
# Your email address used to receive emails
IMAP_USER=your-email@example.com
# Your email account password or app-specific password
IMAP_PASS=your-imap-password

# --- SMTP Configuration (Outgoing Email) ---
# Host of your SMTP server (e.g., smtp.gmail.com)
SMTP_HOST=smtp.example.com
# SMTP port — 587 for STARTTLS, 465 for SSL, 25 for plain
SMTP_PORT=587
# Your email address used to send emails (usually same as IMAP_USER)
SMTP_USER=your-email@example.com
# Your email account password or app-specific password
SMTP_PASS=your-smtp-password
